{
  "manifest_version": 3,
  "name": "ADX Dashboard Agent",
  "version": "1.0.0",
  "description": "Enables agentic editing of Azure Data Explorer dashboards",
  "permissions": ["activeTab", "scripting"],
  "host_permissions": ["https://dataexplorer.azure.com/*"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://dataexplorer.azure.com/dashboards/*"],
      "js": ["agent-script.js"],
      "run_at": "document_idle",
      "world": "MAIN"
    }
  ],
  "externally_connectable": {
    "matches": ["http://localhost:*/*"]
  },
  "background": {
    "service_worker": "background.js"
  }
}
